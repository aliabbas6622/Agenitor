# ── Database ──────────────────────────────────────────────
# SECURITY: Generate strong random passwords for production!
# Example: openssl rand -base64 32
DATABASE_URL=postgresql+asyncpg://editor:CHANGE_ME_STRONG_PASSWORD@localhost:5432/ai_video_editor
DATABASE_URL_SYNC=postgresql+psycopg2://editor:CHANGE_ME_STRONG_PASSWORD@localhost:5432/ai_video_editor

# ── Redis ─────────────────────────────────────────────────
# For production: use redis://[:password]@localhost:6379/0 with requirepass in redis.conf
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Application ──────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────
# SECURITY: Restrict to your actual frontend domains in production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── AI Provider Keys ──────────────────────────────────────
# SECURITY: Never commit real keys to version control
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
Pexels_API_KEY=
PIXABAY_API_KEY=
